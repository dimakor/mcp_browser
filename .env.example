# The port the internal Express server will run on
PORT=8000

# The secret API Key that Google Antigravity must use to connect
API_KEY=your_super_secret_api_key

# Optional: Path to a specific Chrome executable if needed (usually blank on Ubuntu)
# CHROME_PATH=/usr/bin/google-chrome

# Optional proxy limits
# PROXY_TIMEOUT_MS=45000
# PROXY_FETCH_MAX_BYTES=2000000
# PROXY_DOWNLOAD_MAX_BYTES=8000000
# PROXY_MAX_CHARS=60000
# PROXY_LINK_LIMIT=200

# Optional host allowlist. Empty means any public HTTP(S) host is allowed.
# Examples:
# PROXY_ALLOWED_HOSTS=ru,xn--p1ai,pecom.ru,tk-kit.ru,dellin.ru,cdek.ru

# Keep enabled unless you intentionally need private/VPC targets from the VPS.
# PROXY_BLOCK_PRIVATE_NETWORKS=true
